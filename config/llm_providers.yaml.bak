# LLM Provider Configuration - 增量扩展模式
# 新增提供商只需在 providers 下追加，无需改动代码
# 优先级由 priority 决定，数值越小优先级越高

providers:
  # OpenCode Zen - 首选的 OpenAI 兼容路由，极速稳定
  - name: opencode_zen
    provider: openai
    model: deepseek-v4-flash-free
    api_key_env: OPENCODE_ZEN_API_KEY  # 从 .env 读取，禁止硬编码
    base_url: https://api.opencode-zen.com/v1
    priority: 5
    max_tokens_per_minute: 50000
    max_requests_per_minute: 100
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # Cerebras - 极速推理，免信用卡，1M tokens/天免费
  - name: cerebras
    provider: cerebras
    model: llama-3.3-70b
    api_key_env: CEREBRAS_API_KEY
    base_url: https://api.cerebras.ai/v1
    priority: 12
    max_tokens_per_minute: 100000
    max_requests_per_minute: 60
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # 阿里云百炼 - 中文理解最强之一，100万 Token 免费
  - name: alibaba_bailian
    provider: alibaba
    model: qwen-max
    api_key_env: ALIBABA_API_KEY
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    priority: 18
    max_tokens_per_minute: 50000
    max_requests_per_minute: 100
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # Gemini - Google 免费额度大，支持长上下文
  - name: gemini_flash
    provider: gemini
    model: gemini-2.0-flash
    api_key_env: GEMINI_API_KEY  # 从 .env 读取，禁止硬编码
    priority: 10
    max_tokens_per_minute: 30000
    max_requests_per_minute: 60
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # 智谱 AI - GLM-4-Flash 部分永久免费，中文优秀
  - name: zhipu_glm
    provider: zhipu
    model: glm-4-flash
    api_key_env: ZHIPU_API_KEY
    base_url: https://open.bigmodel.cn/api/paas/v4
    priority: 22
    max_tokens_per_minute: 50000
    max_requests_per_minute: 100
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # 硅基流动 SiliconCloud - 千万 Token 级测试包，永久额度
  - name: siliconcloud
    provider: siliconcloud
    model: Qwen/Qwen2.5-72B-Instruct
    api_key_env: SILICONCLOUD_API_KEY
    base_url: https://api.siliconflow.cn/v1
    priority: 25
    max_tokens_per_minute: 50000
    max_requests_per_minute: 60
    stages: [analyze, judge]
    enabled: true

  # NVIDIA Nemotron - 免费高质量
  - name: nvidia_nemotron
    provider: openai
    model: nvidia/minimaxai/minimax-m2.7
    api_key_env: NVIDIA_API_KEY  # 从 .env 读取，禁止硬编码
    base_url: https://integrate.api.nvidia.com/v1
    priority: 15
    max_tokens_per_minute: 4000
    max_requests_per_minute: 20
    stages: [analyze, judge]
    enabled: true

  # Mistral AI - 实验层最高 1B tokens/月，欧洲合规
  - name: mistral
    provider: mistral
    model: mistral-small-latest
    api_key_env: MISTRAL_API_KEY  # 从 .env 读取，禁止硬编码
    base_url: https://api.mistral.ai/v1
    priority: 28
    max_tokens_per_minute: 50000
    max_requests_per_minute: 60
    stages: [annotate, edit]
    enabled: true

  # DeepSeek - 中文理解强，备选
  - name: deepseek
    provider: deepseek
    model: deepseek-chat
    api_key_env: DEEPSEEK_API_KEY
    priority: 20
    max_tokens_per_minute: 8000
    max_requests_per_minute: 30
    stages: [annotate, edit, judge]
    enabled: true

  # 百度千帆 - 文心+DeepSeek+Qwen，每模型 100 万 Token
  - name: baidu_qianfan
    provider: baidu_qianfan
    model: ernie-speed-128k
    api_key_env: BAIDU_API_KEY
    base_url: https://qianfan.baidubce.com/v2
    priority: 32
    max_tokens_per_minute: 30000
    max_requests_per_minute: 60
    stages: [annotate, edit]
    enabled: true

  # 火山引擎 - 豆包大模型，500 万 Token 活动额度
  - name: volcengine
    provider: volcengine
    model: doubao-pro-32k
    api_key_env: VOLCENGINE_API_KEY
    base_url: https://ark.cn-beijing.volces.com/api/v3
    priority: 35
    max_tokens_per_minute: 30000
    max_requests_per_minute: 60
    stages: [annotate, edit]
    enabled: true

  # 腾讯云混元 - 混元全系列，100 万 Token 有效期 1 年
  - name: tencent_hunyuan
    provider: tencent
    model: hunyuan-standard
    api_key_env: TENCENT_API_KEY
    base_url: https://hunyuan.tencentcloudapi.com
    priority: 38
    max_tokens_per_minute: 30000
    max_requests_per_minute: 60
    stages: [annotate, edit]
    enabled: true

  # HuggingFace - 数千开源模型，按模型限速
  - name: huggingface
    provider: huggingface
    model: Qwen/Qwen2.5-72B-Instruct
    api_key_env: HF_API_KEY
    base_url: https://api-inference.huggingface.co/v1
    priority: 45
    max_tokens_per_minute: 10000
    max_requests_per_minute: 20
    stages: [extract, analyze]
    enabled: true

  # OpenRouter - 聚合多模型，兜底
  - name: openrouter
    provider: openrouter
    model: meta-llama/llama-3.1-8b-instruct:free
    api_key_env: OPENROUTER_API_KEY  # 从 .env 读取，禁止硬编码
    priority: 30
    max_tokens_per_minute: 5000
    max_requests_per_minute: 20
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # Cloudflare Workers AI - 边缘推理，低延迟
  - name: cloudflare_ai
    provider: cloudflare
    model: "@cf/meta/llama-3.3-70b"
    api_key_env: CLOUDFLARE_API_KEY
    base_url: https://api.cloudflare.com/client/v4/accounts/{account_id}/ai/run
    priority: 50
    max_tokens_per_minute: 10000
    max_requests_per_minute: 30
    stages: [annotate, edit]
    enabled: true

  # GitHub Models - 开发者免费，GitHub 生态集成
  - name: github_models
    provider: github
    model: gpt-4o-mini
    api_key_env: GITHUB_API_KEY
    base_url: https://models.inference.ai.azure.com
    priority: 55
    max_tokens_per_minute: 10000
    max_requests_per_minute: 30
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # Groq 70B - 降级兜底（大模型质量高但限流严格）
  - name: groq_70b
    provider: groq
    model: llama-3.3-70b-versatile
    api_key_env: GROQ_API_KEY
    priority: 90
    max_tokens_per_minute: 10000
    max_requests_per_minute: 20
    stages: [analyze, judge]
    enabled: true

  # Groq 8B - 最后兜底（小模型快但上下文短）
  - name: groq_8b
    provider: groq
    model: llama-3.1-8b-instant
    api_key_env: GROQ_API_KEY
    priority: 95
    max_tokens_per_minute: 5000
    max_requests_per_minute: 30
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # 本地 Ollama - 零成本、无限制、离线可用（终极兜底）
  - name: ollama_qwen25
    provider: ollama
    model: qwen2.5:14b
    base_url: http://localhost:11434
    priority: 70
    max_tokens_per_minute: 100000
    max_requests_per_minute: 100
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  - name: ollama_llama31
    provider: ollama
    model: llama3.1:8b
    base_url: http://localhost:11434
    priority: 75
    max_tokens_per_minute: 100000
    max_requests_per_minute: 100
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

# Prompt 压缩策略 - 激进模式以适应 TPM 限制
prompt_compression:
  max_input_tokens: 2500
  truncate_strategy: smart
  remove_few_shot_when_long: true
  min_few_shot_examples: 0
  schema_injection_mode: minimal

# 降级策略
fallback:
  max_retries_per_provider: 1
  retry_on_rate_limit: true
  retry_on_timeout: true
  timeout_seconds: 45
  exponential_backoff_base: 1.5

# 成本控制
cost_control:
  daily_limit_usd: 10.0
  alert_threshold: 0.8
  track_per_stage: true