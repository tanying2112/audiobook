# LLM Provider Configuration - 增量扩展模式
# 新增提供商只需在 providers 下追加，无需改动代码
# 优先级由 priority 决定，数值越小优先级越高
#
# ⚠️ 安全警告：本文件为模板，所有 api_key_env 字段填写环境变量名（非密钥本身）
# 实际密钥请写入 .env 文件（已被 .gitignore 忽略）
# 使用时复制本文件为 llm_providers.yaml，并确保 .env 中有对应的环境变量

providers:
  # OpenCode Zen - 首选的 OpenAI 兼容路由，极速稳定
  - name: opencode_zen
    provider: openai
    model: deepseek-v4-flash-free
    api_key_env: OPENCODE_ZEN_API_KEY  # 从 .env 读取
    base_url: https://api.opencode-zen.com/v1
    priority: 5
    max_tokens_per_minute: 50000
    max_requests_per_minute: 100
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # Cerebras - 极速推理，免信用卡，1M tokens/天免费
  - name: cerebras
    provider: cerebras
    model: llama-3.3-70b
    api_key_env: CEREBRAS_API_KEY
    base_url: https://api.cerebras.ai/v1
    priority: 12
    max_tokens_per_minute: 100000
    max_requests_per_minute: 60
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # 阿里云百炼 - 中文理解最强之一，100万 Token 免费
  - name: alibaba_bailian
    provider: alibaba
    model: qwen-max
    api_key_env: ALIBABA_API_KEY
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    priority: 18
    max_tokens_per_minute: 50000
    max_requests_per_minute: 100
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # Gemini - Google 免费额度大，支持长上下文
  - name: gemini_flash
    provider: gemini
    model: gemini-2.0-flash
    api_key_env: GEMINI_API_KEY  # 从 .env 读取
    priority: 10
    max_tokens_per_minute: 30000
    max_requests_per_minute: 60
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # 智谱 AI - GLM-4-Flash 部分永久免费，中文优秀
  - name: zhipu_glm
    provider: zhipu
    model: glm-4-flash
    api_key_env: ZHIPU_API_KEY
    base_url: https://open.bigmodel.cn/api/paas/v4
    priority: 22
    max_tokens_per_minute: 50000
    max_requests_per_minute: 100
    stages: [extract, analyze, annotate, edit, judge]
    enabled: true

  # 硅基流动 SiliconCloud - 千万 Token 级测试包，永久额度
  - name: siliconcloud
    provider: siliconcloud
    model: Qwen/Qwen2.5-72B-Instruct
    api_key_env: SILICONCLOUD_API_KEY
    base_url: https://api.siliconflow.cn/v1
    priority: 25
    max_tokens_per_minute: 50000
    max_requests_per_minute: 60
    stages: [analyze, judge]
    enabled: true

  # NVIDIA Nemotron - 免费高质量
  - name: nvidia_nemotron
    provider: openai
    model: nvidia/minimaxai/minimax-m2.7
    api_key_env: NVIDIA_API_KEY  # 从 .env 读取
    base_url: https://integrate.api.nvidia.com/v1
    priority: 15
    max_tokens_per_minute: 4000
    max_requests_per_minute: 20
    stages: [analyze, judge]
    enabled: true

  # Mistral AI - 实验层最高 1B tokens/月，欧洲合规
  - name: mistral
    provider: mistral
    model: mistral-small-latest
    api_key_env: MISTRAL_API_KEY  # 从 .env 读取
    base_url: https://api.mistral.ai/v1
    priority: 28
    max_tokens_per_minute: 50000
    max_requests_per_minute: 60
    stages: [annotate, edit]
    enabled: true

  # DeepSeek - 中文理解强，备选
  - name: deepseek
    provider: deepseek
    model: deepseek-chat
    api_key_env: DEEPSEEK_API_KEY
    priority: 20
    max_tokens_per_minute: 8000
    max_requests_per_minute: 30
    stages: [annotate, edit, judge]
    enabled: true

  # 百度千帆 - 文心+DeepSeek+Qwen，每模型 100 万 Token
  - name: baidu_qianfan
    provider: baidu_qianfan
    model: ernie-speed-128k
    api_key_env: BAIDU_API_KEY
    base_url: https://qianfan.baidubce.com/v2
    priority: 32
    max_tokens_per_minute: 30000
    max_requests_per_minute: 60
    stages: [annotate, edit]
    enabled: true

  # 火山引擎 - 豆包大模型，500 万 Token 活动额度
  - name: volcengine
    provider: volcengine
    model: doubao-pro-32k
    api_key_env: VOLCENGINE_API_KEY
    base_url: https://ark.cn-beijing.volces.com/api/v3
    priority: 35
    max_tokens_per_minute: 30000
    max_requests_per_minute: 60
    stages: [annotate, edit]
    enabled: true
