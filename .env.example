# Audiobook Studio — 环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env
# 严禁提交 .env 到 Git（已在 .gitignore 中）

# =============================================================================
# 数据库配置 (PostgreSQL 推荐用于生产)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/audiobook
# SQLite 开发备选: DATABASE_URL=sqlite:///./data/audiobook.db

# =============================================================================
# 安全配置
# =============================================================================
SECRET_KEY=your-secret-key-change-in-production
# JWT 算法
JWT_ALGORITHM=HS256
# Token 过期时间(分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# LLM 提供商 API Keys (按需填入，至少配置一个)
# 优先级可在 config/llm_providers.yaml 中调整
# =============================================================================
# 默认 LLM 提供商 (用于简单场景)
LLM_PROVIDER=gemini
# OpenCode Zen (首选 OpenAI 兼容路由，极速稳定)
OPENCODE_ZEN_API_KEY=your-opencode-zen-api-key

# OpenAI (GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=your-openai-api-key

# Anthropic (Claude 3.5 Sonnet, Haiku)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini (Gemini 2.0 Flash, Pro Vision)
GEMINI_API_KEY=your-gemini-api-key
# 多 Key 池支持 (可选)
# GEMINI_API_KEY_2=your-second-gemini-api-key
# GEMINI_API_KEY_3=your-third-gemini-api-key

# Groq (Llama-3.1-70B, 8B - 极快免费)
GROQ_API_KEY=your-groq-api-key

# OpenRouter (聚合多模型统一入口)
OPENROUTER_API_KEY=your-openrouter-api-key

# DeepSeek (DeepSeek-V3, Chat - 中文强)
DEEPSEEK_API_KEY=your-deepseek-api-key

# NVIDIA (Nemotron 3 Ultra)
NVIDIA_API_KEY=your-nvidia-api-key

# Cerebras (极速推理，免信用卡，1M tokens/天免费)
CEREBRAS_API_KEY=your-cerebras-api-key

# 阿里云百炼 (中文理解最强之一，100万 Token 免费)
ALIBABA_API_KEY=your-alibaba-api-key

# 智谱 AI (GLM-4-Flash 部分永久免费，中文优秀)
ZHIPU_API_KEY=your-zhipu-api-key

# 硅基流动 SiliconCloud (千万 Token 级测试包，永久额度)
SILICONCLOUD_API_KEY=your-siliconcloud-api-key

# Mistral AI (实验层最高 1B tokens/月，欧洲合规)
MISTRAL_API_KEY=your-mistral-api-key

# 百度千帆 (文心+DeepSeek+Qwen，每模型 100 万 Token)
BAIDU_API_KEY=your-baidu-api-key

# 火山引擎 (豆包大模型，500 万 Token 活动额度)
VOLCENGINE_API_KEY=your-volcengine-api-key

# 腾讯云混元 (混元全系列，100 万 Token 有效期 1 年)
TENCENT_API_KEY=your-tencent-api-key

# HuggingFace (数千开源模型，按模型限速)
HF_API_KEY=your-huggingface-api-key

# Cloudflare Workers AI (边缘推理，低延迟)
CLOUDFLARE_API_KEY=your-cloudflare-api-key
# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# GitHub Models (开发者免费，GitHub 生态集成)
GITHUB_API_KEY=your-github-api-key

# =============================================================================
# TTS 服务
# =============================================================================
# ElevenLabs (高质量商业 TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Edge-TTS (微软免费云端 TTS，无需 key)
# 语音列表: https://github.com/rany2/edge-tts#voices

# Azure Cognitive Services TTS (免费额度: 500万字符/月)
# 申请地址: https://azure.microsoft.com/free/cognitive-services/
AZURE_TTS_KEY=your-azure-tts-key
AZURE_TTS_REGION=eastus
# 备用变量名兼容
# AZURE_SPEECH_KEY=your-azure-speech-key
# AZURE_SPEECH_REGION=eastus

# Google Cloud TTS (免费额度: 100万字符/月)
# 申请地址: https://cloud.google.com/text-to-speech/pricing
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json
# 或设置 GCP_PROJECT_ID=your-project-id

# =============================================================================
# Remote VoxCPM2 (Cloudflare Tunnel → Kaggle GPU)
# =============================================================================
# 远程 VoxCPM2 推理端点（通过 Cloudflare Tunnel 访问 Kaggle GPU）
VOICEPM2_REMOTE_ENDPOINT=https://voxcpm2.guwj609.ccwu.cc/generate
# 连接超时(秒)
VOICEPM2_CONNECT_TIMEOUT=5.0
# 读取超时(秒) - TTS 推理可能耗时较长
VOICEPM2_READ_TIMEOUT=120.0
# 写入超时(秒)
VOICEPM2_WRITE_TIMEOUT=30.0
# 连接池超时(秒)
VOICEPM2_POOL_TIMEOUT=10.0
# 最大重试次数
VOICEPM2_MAX_RETRIES=3
# 指数退避最小等待(秒)
VOICEPM2_RETRY_MIN_WAIT=2.0
# 指数退避最大等待(秒)
VOICEPM2_RETRY_MAX_WAIT=30.0
# 熔断器失败阈值
VOICEPM2_CB_THRESHOLD=3
# 熔断器恢复超时(秒)
VOICEPM2_CB_TIMEOUT=120.0

# =============================================================================
# 文本提取服务
# =============================================================================
# 如使用云端 OCR: AWS Textract, Google Vision, Azure Form Recognizer
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# =============================================================================
# 应用配置
# =============================================================================
LOG_LEVEL=INFO
PYTHONPATH=.
AUDIO_OUTPUT_DIR=./output
CHECKPOINTS_DIR=./checkpoints

# 成本控制 (单位: 美元)
COST_LIMIT_PER_CHAPTER=5.0
COST_LIMIT_PER_BOOK=20.0
COST_ALERT_THRESHOLD=0.8  # 80% 告警

# LLM 路由策略 (JSON 格式，也可用单独配置文件)
# 阶段: 模型列表(按优先序)，支持同模型多阶段
# LLM_ROUTING_CONFIG='{"extract": ["gemini-2.0-flash", "gpt-4o"], "analyze": ["gemini-2.0-flash", "claude-3.5-sonnet"], "annotate": ["groq/llama-3.1-70b", "deepseek-chat"], "edit": ["deepseek-chat", "gpt-4o"], "route": ["kokoro", "edge"], "judge": ["claude-3.5-sonnet", "gemini-2.0-flash"]}'

# =============================================================================
# 监控与可观测性 (可选)
# =============================================================================
# Langfuse (推荐：Trace + 评估 + Prompt 管理)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Prometheus/Grafana
PROMETHEUS_ENABLED=false
GRAFANA_ENABLED=false

# =============================================================================
# 发布服务
# =============================================================================
# Audiobookshelf (有声书管理平台)
AUDIOBOOKSHELF_API_KEY=your-audiobookshelf-api-key

# =============================================================================
# 开发/调试
# =============================================================================
DEBUG=false
MOCK_LLM=false  # true 时使用模拟响应，便于离线开发
