        self.temp_dir = tempfile.mkdtemp()
        self.pipeline = SynthesizePipeline(output_dir=self.temp_dir)

    def teardown_method(self):
        """Clean up test fixtures."""
        import shutil
        shutil.rmtree(self.temp_dir, ignore_errors=True)

    def test_text_hash(self):
        """Test text_hash method for caching."""
        pipeline = SynthesizePipeline()
        hash1 = pipeline._text_hash("测试文本")
        hash2 = pipeline._text_hash("测试文本")
        hash3 = pipeline._text_hash("不同文本")
        assert hash1 == hash2
        assert hash1 != hash3

    def test_synthesize_kokoro_real_mode(self):
        """Test kokoro synthesis in real mode - skipped due to external dependencies."""
        pytest.skip("External kokoro-onnx dependency not available in test environment")

    def test_synthesize_edge_real_mode(self):
        """Test Edge-TTS synthesis in real mode - skipped due to external dependencies."""
        pytest.skip("External edge-tts dependency not available in test environment")

    def test_synthesize_edge_exception_fallback(self):
        """Test Edge-TTS exception triggers fallback estimate - skipped due to external dependencies."""
        pytest.skip("External edge-tts dependency not available in test environment")

    def test_crossfade_stitch_mock_mode(self):
        """Test crossfade stitching in mock mode."""
        segments = [
            AudioSegment("seg1", "/tmp/seg1.mp3", 1000, "kokoro", "v1", "hash1"),
            AudioSegment("seg2", "/tmp/seg2.mp3", 1000, "edge", "v2", "hash2"),
        ]

        pipeline = SynthesizePipeline(mock_mode=True)

        # In mock mode, it just returns sum of durations
        result = pipeline._crossfade_stitch(segments, Path(self.temp_dir) / "output.mp3")

        assert result is not None
        assert result == 2000

    def test_crossfade_stitch_empty_segments(self):
        """Test crossfade with empty segments list."""
