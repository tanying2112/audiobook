            "voice_id": "v1",
            "text_hash": "different_hash",
        }
        metadata_path.write_text(json.dumps(metadata))

        segment = pipeline._load_existing_segment_from_disk(segment_id, "expected_hash")
        assert segment is None

    def test_load_existing_segment_from_disk_missing_file(self):
        """Test _load_existing_segment_from_disk when audio file is missing."""
        import json
