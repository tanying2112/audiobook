    def test_persist_segment_metadata(self):
        """Test _persist_segment_metadata creates valid JSON."""
        pipeline = SynthesizePipeline()
        segment = AudioSegment(
            segment_id="test_persist",
            file_path="/tmp/test.mp3",
            duration_ms=2500,
            engine="kokoro",
            voice_id="v1",
            text_hash="persist_hash",
        )

        pipeline._persist_segment_metadata(segment)

        metadata_path = pipeline._metadata_path("test_persist")
        assert metadata_path.exists()

        import json
        metadata = json.loads(metadata_path.read_text())
        assert metadata["segment_id"] == "test_persist"
        assert metadata["text_hash"] == "persist_hash"

    def test_persist_segment_metadata_write_error(self):
        """Test _persist_segment_metadata handles write errors gracefully."""
        import json
        pipeline = SynthesizePipeline()
        # Make output dir read-only to trigger error
        import stat
        os.chmod(self.temp_dir, stat.S_IRUSR | stat.S_IXUSR)

        try:
            segment = AudioSegment(
                segment_id="test_perm",
                file_path="/tmp/test.mp3",
                duration_ms=2500,
                engine="kokoro",
                voice_id="v1",
                text_hash="hash",
            )
            # Should not raise, just log warning
            pipeline._persist_segment_metadata(segment)
        finally:
            os.chmod(self.temp_dir, stat.S_IRWXU)

    def test_get_tts_engine_config(self):
        """Test _get_tts_engine_config returns config from hardware profile."""
        pipeline = SynthesizePipeline()
        config = pipeline._get_tts_engine_config()
        assert isinstance(config, dict)
        assert "engine" in config
        assert "fallback_chain" in config

    def test_get_tts_engine_config_no_hardware_profile(self):
        """Test _get_tts_engine_config when no hardware profile."""
        import tempfile
        from unittest.mock import patch

        with patch("src.audiobook_studio.pipeline.synthesize.get_hardware_profile") as mock_get_profile:
            mock_get_profile.return_value = None

            pipeline = SynthesizePipeline()
            config = pipeline._get_tts_engine_config()

            assert config == {"engine": "kokoro", "fallback_chain": []}


