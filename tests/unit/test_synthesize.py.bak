class TestSynthesizeCrossfadeFFmpeg:
    """Tests for crossfade_stitch ffmpeg execution paths."""

    def test_crossfade_stitch_ffmpeg_not_found(self, tmp_path):
        """Test _crossfade_stitch falls back when ffmpeg not found."""
        pipeline = SynthesizePipeline()

        # Create mock segments
        seg_file = tmp_path / "seg.mp3"
        seg_file.write_bytes(b"RIFF")

        from src.audiobook_studio.pipeline.synthesize import AudioSegment
        segments = [AudioSegment(
            segment_id="s1", file_path=str(seg_file), duration_ms=1000,
            engine="test", voice_id="v1", text_hash="h1"
        )]

        with patch("src.audiobook_studio.pipeline.synthesize.subprocess.run", side_effect=FileNotFoundError("ffmpeg not found")):
            result = pipeline._crossfade_stitch(segments, tmp_path / "out.mp3")
            # Falls back to simple concat which returns sum in mock mode error path
            assert result >= 0

    def test_crossfade_stitch_ffmpeg_error_fallback(self, tmp_path):
        """Test _crossfade_stitch falls back on ffmpeg error."""
        pipeline = SynthesizePipeline()

        seg_file = tmp_path / "seg.mp3"
        seg_file.write_bytes(b"RIFF")

        from src.audiobook_studio.pipeline.synthesize import AudioSegment
        segments = [AudioSegment(
            segment_id="s1", file_path=str(seg_file), duration_ms=1000,
            engine="test", voice_id="v1", text_hash="h1"
        )]

        mock_result = MagicMock()
        mock_result.returncode = 1
        mock_result.stderr = "ffmpeg error"

        with patch("src.audiobook_studio.pipeline.synthesize.subprocess.run", return_value=mock_result):
            with patch("src.audiobook_studio.pipeline.synthesize.get_duration_sync", return_value=1000):
                result = pipeline._crossfade_stitch(segments, tmp_path / "out.mp3")

    def test_crossfade_stitch_tracing_enabled(self, tmp_path):
        """Test _crossfade_stitch with tracing enabled."""
        pipeline = SynthesizePipeline()

        seg_file = tmp_path / "seg.mp3"
        seg_file.write_bytes(b"RIFF")

        from src.audiobook_studio.pipeline.synthesize import AudioSegment
        segments = [AudioSegment(
            segment_id="s1", file_path=str(seg_file), duration_ms=1000,
            engine="test", voice_id="v1", text_hash="h1"
        )]

        with patch("src.audiobook_studio.pipeline.synthesize.is_enabled", return_value=True):
            with patch("src.audiobook_studio.pipeline.synthesize.subprocess.run", side_effect=FileNotFoundError()):
                result = pipeline._crossfade_stitch(segments, tmp_path / "out.mp3")


class TestSynthesizeEdgeRealModePaths:
    """Tests for edge cases in real mode synthesis."""

    def setup_method(self):
        """Setup test fixtures."""
        self.temp_dir = tempfile.mkdtemp()

    def teardown_method(self):
        """Clean up test fixtures."""
        import shutil
        shutil.rmtree(self.temp_dir, ignore_errors=True)

    def test_synthesize_edge_with_import_error(self, tmp_path):
        """Test _synthesize_edge handles ImportError and falls back."""
        output_path = tmp_path / "test.mp3"
        output_path.write_bytes(b"RIFF dummy audio")

        # Create pipeline with mock_mode=True to avoid real LLM calls
        pipeline = SynthesizePipeline(mock_mode=True, output_dir=tmp_path)

        # In mock mode, _synthesize_edge returns fixed 2800ms and creates dummy file
        duration = pipeline._synthesize_edge("test", "voice", {}, output_path)
        assert duration == 2800
        assert output_path.exists()

    def test_synthesize_edge_fallback_estimate(self, tmp_path):
        """Test _synthesize_edge duration estimation fallback."""
        output_path = tmp_path / "test.mp3"
        # Write dummy audio file first
        output_path.write_bytes(b"RIFF" + b"\x00" * 1000)

        pipeline = SynthesizePipeline(mock_mode=False, output_dir=tmp_path)

        # Mock get_duration_sync to fail, triggering text-based estimation
        with patch('src.audiobook_studio.pipeline.synthesize.get_duration_sync', side_effect=ValueError("no ffprobe")):
            # Mock asyncio.run to simulate successful synthesis
            async def dummy_coro():
                pass
            with patch('asyncio.run', return_value=None):
                with patch('src.audiobook_studio.pipeline.synthesize.SynthesizePipeline._resolve_edge_voice', return_value="test-voice"):
                    # Should estimate from text length
                    duration = pipeline._synthesize_edge("这是一段中文测试文本用于估计时长", "voice", {"rate": "1.0"}, output_path)
                    # Fallback estimation for Chinese: chars/3.5 * 1000ms
                    assert duration >= 500  # At least the minimum

    def test_persist_segment_metadata_called(self, tmp_path):
        """Test _persist_segment_metadata is called during run."""
        from src.audiobook_studio.pipeline.synthesize import AudioSegment
        pipeline = SynthesizePipeline(mock_mode=True, output_dir=tmp_path)
        
        # Create test audio file
        audio_path = tmp_path / "test.mp3"
        audio_path.write_bytes(b"RIFF")
        
        segment = AudioSegment(
            segment_id="test_seg",
            file_path=str(audio_path),
            duration_ms=1000,
            engine="kokoro",
            voice_id="v1",
            text_hash="hash",
        )
        
        # Call persist directly
        pipeline._persist_segment_metadata(segment)


class TestSynthesizeAzureGCPSimple:
    """Simple tests for Azure/GCP coverage."""

    def test_synthesize_gcp_prosody(self, tmp_path):
        """Test _synthesize_gcp with prosody parameters."""
        import os
        from src.audiobook_studio.pipeline.synthesize import SynthesizePipeline
        pipeline = SynthesizePipeline(mock_mode=False, output_dir=tmp_path)
        
        creds_file = tmp_path / "creds.json"
        creds_file.write_text('{}')
        
        with patch.dict(os.environ, {"GOOGLE_APPLICATION_CREDENTIALS": str(creds_file)}, clear=True):
            mock_client = MagicMock()
            mock_response = MagicMock()
            mock_response.audio_content = b"test"
            mock_client.synthesize_speech.return_value = mock_response
            
            mock_gcp = MagicMock()
            mock_gcp.TextToSpeechClient.return_value = mock_client
            
            with patch('src.audiobook_studio.pipeline.synthesize.get_duration_sync', return_value=3000):
                with patch.dict('sys.modules', {'google.cloud.texttospeech': mock_gcp}):
                    duration = pipeline._synthesize_gcp("test", "cmn-CN-Neural2-A", {"rate": 1.2}, tmp_path / "out.mp3")
                    assert duration == 3000


if __name__ == "__main__":
    pytest.main([__file__, "-v"])
