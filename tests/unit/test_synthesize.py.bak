    def test_load_existing_segment_from_disk_valid(self):
        """Test _load_existing_segment_from_disk with valid metadata."""
        import json
        pipeline = SynthesizePipeline()
        segment_id = "test_seg_1"
        text_hash = "abc123"
        output_path = Path(self.temp_dir) / f"{segment_id}.mp3"
        output_path.write_bytes(b"RIFF" + b"\x00" * 1000)

        metadata_path = pipeline._metadata_path(segment_id)
        metadata = {
            "segment_id": segment_id,
            "file_path": str(output_path),
            "duration_ms": 3000,
            "engine": "kokoro",
            "voice_id": "v1",
            "text_hash": text_hash,
        }
        metadata_path.write_text(json.dumps(metadata))

        segment = pipeline._load_existing_segment_from_disk(segment_id, text_hash)

        assert segment is not None
        assert segment.segment_id == segment_id
        assert segment.file_path == str(output_path)
        assert segment.duration_ms == 3000
        assert segment.text_hash == text_hash

    def test_load_existing_segment_from_disk_missing_metadata(self):
        """Test _load_existing_segment_from_disk with missing metadata file."""
        pipeline = SynthesizePipeline()
        segment = pipeline._load_existing_segment_from_disk("nonexistent", "hash123")
        assert segment is None

