import sys
import os
from unittest.mock import MagicMock, patch

# Add the src directory to the path so we can import the module as a package
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '../../../src'))

# Mock the dependencies
# Mock numpy
sys.modules['numpy'] = MagicMock()

# Mock dspy and its submodules
sys.modules['dspy'] = MagicMock()
sys.modules['dspy.teleprompt'] = MagicMock()
sys.modules['dspy.teleprompt.gepa'] = MagicMock()
sys.modules['dspy.teleprompt.gepa.gepa_utils'] = MagicMock()
sys.modules['dspy.evaluate'] = MagicMock()
sys.modules['dspy.predict'] = MagicMock()
sys.modules['dspy.primitives'] = MagicMock()
sys.modules['dspy.utils'] = MagicMock()
sys.modules['dspy.clients'] = MagicMock()

# Mock litellm and its submodules
sys.modules['litellm'] = MagicMock()
sys.modules['litellm._logging'] = MagicMock()
sys.modules['litellm.utils'] = MagicMock()

# Mock other potentially problematic modules
sys.modules['torch'] = MagicMock()
sys.modules['torchaudio'] = MagicMock()
sys.modules['funasr'] = MagicMock()
sys.modules['whisper'] = MagicMock()
sys.modules['faster_whisper'] = MagicMock()
sys.modules['onnxruntime'] = MagicMock()
sys.modules['speechbrain'] = MagicMock()

# Now we can import the module
import unittest
import numpy as np

from audiobook_studio.quality.metrics import (
    DNSMOSMetric,
    ASRWerMetric,
    SpeakerSimilarityMetric,
    DNSMOSResult,
    WERResult,
    SpeakerSimilarityResult,
    FunASRBackend,
    WhisperBackend,
    ECAPATDNNBackend,
    WavLMBackend,
)

class TestDNSMOSMetric(unittest.TestCase):
    def setUp(self):
        self.metric = DNSMOSMetric()

    def test_compute_dnsmos(self):
        # Mock the DNSMOS model output
        with patch('audiobook_studio.quality.metrics.DNSMOSModel') as MockModel:
            mock_instance = MockModel.return_value
            mock_instance.return_value = {"ovrl": 4.0}
            score = self.metric._compute_dnsmos("dummy.wav")
            self.assertEqual(score, 4.0)

    def test_compute_dnsmos_error(self):
        # Simulate an error in the model
        with patch('audiobook_studio.quality.metrics.DNSMOSModel') as MockModel:
            mock_instance = MockModel.return_value
            mock_instance.return_value = {}
            score = self.metric._compute_dnsmos("dummy.wav")
            self.assertEqual(score, 0.0)  # fallback

    def test_compute(self):
        # Mock the audio loading and DNSMOS computation
        with patch('audiobook_studio.quality.metrics.librosa.load') as mock_load, \
             patch.object(self.metric, '_compute_dnsmos') as mock_compute:
            mock_load.return_value = (np.array([0.1, 0.2]), 16000)
            mock_compute.return_value = 3.5
            result = self.metric.compute("dummy.wav")
            self.assertIsInstance(result, DNSMOSResult)
            self.assertEqual(result.ovrl, 3.5)

class TestASRWerMetric(unittest.TestCase):
    def setUp(self):
        self.metric = ASRWerMetric(language='zh')

    def test_compute_wer_cer(self):
        # Test the WER/CER computation helper
        # English words
        wer, cer, ins, dels, subs, ref_w, hyp_w = self.metric._compute_wer_cer('hello world', 'hello word')
        self.assertEqual(subs, 1)
        self.assertEqual(ins, 0)
        self.assertEqual(dels, 0)
        self.assertAlmostEqual(wer, 0.5)  # 1 substitution out of 2 words

        # Chinese characters
        wer, cer, ins, dels, subs = self.metric._compute_wer_cer('你好世界', '你好')
        self.assertEqual(dels, 2)
        self.assertEqual(ins, 0)
        self.assertEqual(subs, 0)
        self.assertAlmostEqual(wer, 1.0)  # 2 deletions out of 2 characters

    @patch('audiobook_studio.quality.metrics.whisper.load_model')
    def test_compute_asr(self, mock_load_model):
        # Mock the Whisper model
        mock_model = MagicMock()
        mock_model.transcribe.return_value = {"text": "hello world"}
        mock_load_model.return_value = mock_model

        # Mock the audio loading
        with patch('audiobook_studio.quality.metrics.librosa.load') as mock_load:
            mock_load.return_value = (np.array([0.1, 0.2]), 16000)
            text = self.metric._compute_asr("dummy.wav")
            self.assertEqual(text, "hello world")

    def test_compute(self):
        # Mock the ASR and WER/CER computation
        with patch.object(self.metric, '_compute_asr') as mock_asr, \
             patch.object(self.metric, '_compute_wer_cer') as mock_wer:
            mock_asr.return_value = "hello world"
            mock_wer.return_value = (0.5, 0.0, 0, 1, 0, 2, 2)  # wer, cer, ins, dels, subs, ref_w, hyp_w
            result = self.metric.compute("dummy.wav", "hello world")
            self.assertIsInstance(result, WERResult)
            self.assertEqual(result.wer, 0.5)

class TestSpeakerSimilarityMetric(unittest.TestCase):
    def setUp(self):
        self.metric = SpeakerSimilarityMetric()

    def test_cosine_similarity(self):
        # Test the cosine similarity function
        sim = self.metric._cosine_similarity([1, 0], [1, 0])
        self.assertAlmostEqual(sim, 1.0)
        sim = self.metric._cosine_similarity([1, 0], [0, 1])
        self.assertAlmostEqual(sim, 0.0)
        sim = self.metric._cosine_similarity([0, 0], [1, 0])
        self.assertEqual(sim, 0.0)  # zero vector

    @patch('audiobook_studio.quality.metrics.speechbrain.pretrained')
    def test_get_embedding(self, mock_pretrained):
        # Mock the speaker encoder
        mock_model = MagicMock()
        mock_model.encode_batch.return_value = [[0.1, 0.2, 0.3]]
        mock_pretrained.from_hparams.return_value = mock_model

        # Mock the audio loading
        with patch('audiobook_studio.quality.metrics.torchaudio.load') as mock_load:
            mock_load.return_value = (torch.tensor([[0.1, 0.2]]), 16000)
            embedding = self.metric._get_embedding("dummy.wav")
            self.assertEqual(embedding, [0.1, 0.2, 0.3])

    def test_compute(self):
        # Mock the embedding extraction and cosine similarity
        with patch.object(self.metric, '_get_embedding') as mock_emb, \
             patch.object(self.metric, '_cosine_similarity') as mock_cos:
            mock_emb.side_effect = [[0.1, 0.2], [0.1, 0.2]]
            mock_cos.return_value = 0.95
            result = self.metric.compute("ref.wav", "hyp.wav")
            self.assertIsInstance(result, SpeakerSimilarityResult)
            self.assertEqual(result.similarity, 0.95)

if __name__ == '__main__':
    unittest.main()
